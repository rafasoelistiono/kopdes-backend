APP_NAME=kopdes-backend
APP_ENV=local
APP_DEBUG=true

# Source SIMKOPDES DB: read-only.
SOURCE_DATABASE_URL=postgresql://readonly_user:password@localhost:5432/simkopdes

# Dashboard DB: writable, owned by team.
# Leave empty to use local SQLite in data_backup/.
DASHBOARD_DATABASE_URL=
DASHBOARD_SQLITE_PATH=data_backup/dashboard.db

# Legacy fallback if SOURCE_DATABASE_URL/DASHBOARD_DATABASE_URL are empty.
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=hackathon_2026
DB_USERNAME=
DB_PASSWORD=
DATABASE_URL=

TABLE_PREFIX=group9_
API_PREFIX=/api/v1
ENABLE_ADMIN_ETL_ENDPOINT=true
ENABLE_SLOW_FALLBACK=false
STALE_AFTER_MINUTES=15
API_STATEMENT_TIMEOUT_MS=3000
ETL_STATEMENT_TIMEOUT_MS=120000

# KOMI LLM rewrite layer. Rule engine remains source of truth.
KOMI_LLM_ENABLED=false
KOMI_LLM_PROVIDER=openrouter
KOMI_LLM_API_KEY=your_gemini_api_key_here_if_provider_gemini
KOMI_LLM_MODEL=deepseek/deepseek-v4-flash
KOMI_LLM_TIMEOUT_SECONDS=8
KOMI_LLM_MAX_OUTPUT_TOKENS=512
KOMI_OPENROUTER_API_KEY=your_openrouter_api_key_here
KOMI_OPENROUTER_SITE_URL=http://localhost:3000
KOMI_OPENROUTER_APP_NAME=SIMKOPDES KOMI
